# GeoSafe — Production environment template
# Copy to .env.prod and fill in EVERY value before deploying.
# NEVER commit the real .env.prod to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=geosafe_user
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=geosafe_db

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_64_char_hex_secret

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://yourdomain.com

# gunicorn worker count (default 2; raise to 4 on 4-core hosts)
WEB_CONCURRENCY=2

LOG_LEVEL=INFO

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Optional: Web Push (VAPID) keys
# Generate with: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_pem().decode()); print(v.public_key.public_bytes_encoded().decode())"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_MAILTO=mailto:admin@yourdomain.com

# ── Frontend ──────────────────────────────────────────────────────────────────
# Passed as a build ARG to the React build; must be empty when nginx proxies /api
# on the same origin (leave blank for same-origin deployment)
REACT_APP_API_BASE_URL=

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80

# ── Docker image tag ──────────────────────────────────────────────────────────
# Set in CI to the git SHA or semver tag for traceability
IMAGE_TAG=latest
