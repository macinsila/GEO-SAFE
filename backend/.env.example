# Example environment variables for GeoSafe backend
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://geosafe_user:geosafe_pass@localhost:5432/geosafe
DEBUG=false
# JWT_SECRET is required. Replace this placeholder with a long, random value.
JWT_SECRET=<replace-with-long-random-secret>
CORS_ORIGINS=http://localhost:3000
AUTO_CREATE_TABLES=false
