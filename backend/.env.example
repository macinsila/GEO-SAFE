# Example environment variables for GeoSafe backend
# Copy this to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://geosafe_user:geosafe_pass@localhost:5432/geosafe
DEBUG=false
# JWT_SECRET is required. Use a long, random value in production.
JWT_SECRET=change-this-in-production
CORS_ORIGINS=http://localhost:3000
AUTO_CREATE_TABLES=false
