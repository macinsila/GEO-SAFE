# ──────────────────────────────────────────────────────────────────
# RENDER DEPLOY için gereken tüm env vars (Render Dashboard'a ekleyin)
# ──────────────────────────────────────────────────────────────────

# Supabase > Settings > Database > Connection String (Session mode, port 5432)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres?ssl=require

# Supabase > Settings > Database > Connection pooling > Host
SUPABASE_POOLER_HOST=aws-0-eu-central-1.pooler.supabase.com

# Minimum 32 karakter rastgele değer — üretmek için:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=<BURAYA-EN-AZ-32-KARAKTER-RASTGELE-DEGER>

# Vercel frontend URL'i (Vercel dashboard'dan alın)
CORS_ORIGINS=https://<proje-adi>.vercel.app

# Vercel wildcard preview URL'leri için (değiştirmeye gerek yok)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Tablo oluşturma: migration ile yapılır, false kalmalı
AUTO_CREATE_TABLES=false
